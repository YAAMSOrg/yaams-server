# YAAMS production environment template.
#
#   cp .env.production.example .env
#   docker compose -f docker-compose.prod.yml run --rm app php artisan key:generate --show
#   # paste the generated key into APP_KEY below, then edit the rest.

APP_NAME=YAAMS
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# Public HTTPS URL served by your reverse proxy.
APP_URL=https://your.domain

LOG_CHANNEL=stack
# Activity-log verbosity: debug | info | warning (see AGENTS.md).
LOG_LEVEL=warning
# How long activity-log rows are kept before activitylog:clean prunes them.
ACTIVITYLOG_RETENTION_DAYS=180

# --- Database (the bundled `db` service) ---------------------------------
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=yaams
DB_USERNAME=yaams
# Set a strong password. DB_ROOT_PASSWORD defaults to this if unset.
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-too

# --- Queue / cache / sessions --------------------------------------------
# `database` needs the bundled worker service (running by default). Set to
# `redis` and enable the redis service in the compose file to use Redis.
QUEUE_CONNECTION=database
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ----------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your.domain
MAIL_FROM_NAME="${APP_NAME}"

# --- App / auth ----------------------------------------------------------
FLEET_PAGE_LIMIT=15
FLIGHT_PAGE_LIMIT=15
# Cookie/session domain and Sanctum stateful domain - your public host.
SESSION_DOMAIN=your.domain
SANCTUM_STATEFUL_DOMAINS=your.domain
